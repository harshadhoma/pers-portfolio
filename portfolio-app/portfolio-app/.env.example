# ============================================================
#  These go into Vercel → Project → Settings → Environment Variables
#  (NOT committed to GitHub — this file is just a reference.)
# ============================================================

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key   # SECRET — server only

# Resend → API Keys
RESEND_API_KEY=re_your_resend_key

# The address you want contact alerts sent to
CONTACT_EMAIL=dhreddy07@gmail.com

# ------------------------------------------------------------
# NOTE: admin.html also needs SUPABASE_URL and the ANON (public) key,
# but those are edited directly inside admin.html (see the marked lines),
# because that file runs in the browser.
# ------------------------------------------------------------
